#include<stdio.h>

int main(){
    
    int rows = 5;
    
    for(int i = 0; i <= rows-1 ; i++){
        
        for(int j = 0; j <=2 *  i; j++){
            printf(" ");
        }
        for(int k = i ; k< rows; k++){
            printf("* ");
        }
        printf("\n");
    }
   

    return 0;
}
