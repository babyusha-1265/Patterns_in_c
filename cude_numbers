#include<stdio.h>

int main(){
    int rows = 5;
    for(int i = 1; i <= rows; i++){
        for(int j = rows; j > i; j--){
            printf(" ");
        }
        for(int k = 1; k <= i; k++){
            if(k = i){
                printf("%d",k);
            }
        }
        for(int j = 1; j < 2*(i-1) ; j++){
            printf(" ");
        }
        for(int k = 2; k <= i; k++){
            if(k = i){
                printf("%d",k);
            }
        }
        printf("\n");
    }
    
    for(int i = rows - 1; i >= 0; i--){
        for(int j = i; j <= rows - 1; j++){
            printf(" ");
        }
        for(int k = 1; k <= i; k++){
            if(k = i){
                printf("%d",k);
            }
        }
        for(int j = 2*(i-1); j > 1 ; j--){
            printf(" ");
        }
        for(int k = 2; k <= i; k++){
            if(k = i){
                printf("%d",k);
            }
        }
    
        printf("\n");
    }
  
    return 0;
}
