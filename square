#include<stdio.h>

int main(){
    int rows = 5;
    for(int i = 0; i<= rows  ;i++ ){
        if(i == 0 || i == rows){
            for(int k = 0 ; k <= rows; k++){
                printf("* ");
            }
        }
        else{
            printf("* ");
            for(int j = 1; j < 2 * rows - 1; j++){
                printf(" ");
            }
            printf("* ");
        }
        printf("\n");
    }
}
